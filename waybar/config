{
    "layer": "top",
    "position": "left",
    "width": 40,
    "spacing": 5,
    "modules-left": ["sway/workspaces", "wlr/taskbar"],
    "modules-center": [],
    "modules-right": ["cpu", "memory", "pulseaudio", "clock", "battery"],

    "cpu": {
        "interval": 1,
        "format": "C{usage}%"
    },
    "memory": {
        "interval": 1,
        "format": "M{percentage}%",
        "tooltip-format": "RAM: {used:0.1f}GB / {total:0.1f}GB ({percentage}%)"
    },
    "pulseaudio": {
        "format": "{icon}\n{volume}%",
        "format-muted": "󰝟",
        "format-icons": {
            "default": ["󰕿", "󰖀", "󰕾"]
        },
        "on-click": "pavucontrol"
    },
    "clock": {
        "format": "{:%m/%d\n%H:%M}"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}%",
        "format-charging": "[{capacity}%]",
        "format-plugged": "[{capacity}%]",
    },
    "wlr/taskbar": {
        "format": "{icon}",
        "on-click": "activate",
        "on-click-middle": "close"
    }
}
