{
    "layer": "top",
    "position": "left",
    "width": 40,
    "spacing": 5,
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["sway/window"],
    "modules-right": ["pulseaudio", "clock", "battery"],

    "pulseaudio": {
        "format": "{icon}\n{volume}%",
        "format-muted": "󰝟",
        "format-icons": {
            "default": ["󰕿", "󰖀", "󰕾"]
        },
        "on-click": "pavucontrol"
    },
    "clock": {
        "format": "{:%m/%d\n%H:%M}"
    },
    "battery": {
        "format": "{capacity}%"
    }
}
